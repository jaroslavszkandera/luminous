import { Palette } from "std-widgets.slint";
import { ImgFmt, EditOp, EditOpKind } from "common.slint";
import { SidePanel } from "side-panel.slint";
import { EditsPanel } from "edits-panel.slint";

export enum MouseModeFull {
    default,
    segment,
}

export component FullView inherits TouchArea {
    in property <image> current-image;
    in property <int> curr-image-index;
    in property <string> curr-image-name;
    in property <int> total-images;
    in property <bool> timer-running: false;
    in property <image> mask-overlay;
    in property <string> plugin-status;
    in-out property <bool> panel-visible: false;

    callback request-next-image();
    callback request-prev-image();
    callback exit-full-view();
    callback request-segmentation(int, int);
    callback save-with-format(ImgFmt);
    callback apply-edit(EditOp);

    property <string> display-coords: "0,0";
    property <float> zoom-scale: 1.0;
    property <length> last-coords-x;
    property <length> last-coords-y;
    property <MouseModeFull> mouse-mode: MouseModeFull.default;
    property <length> start-drag-x;
    property <length> start-drag-y;
    property <length> start-img-x;
    property <length> start-img-y;
    property <bool> selecting: self.pressed && root.mouse-x != root.start-drag-x && root.mouse-y != root.start-drag-y;
    property <length> selection-x;
    property <length> selection-y;
    property <length> selection-width;
    property <length> selection-height;
    property <length> side-panel-width: 240px;
    property <bool> dragging: false;
    property <float> pinch-initial-scale: 1.0;

    mouse-cursor: (mouse-mode == MouseModeFull.segment) ? default : (root.dragging && zoom-scale > 1.0) ? grabbing : (zoom-scale > 1.0) ? grab : crosshair;

    coords-timer := Timer {
        interval: 60ms;
        running: root.timer-running;
        triggered => {
            if (root.mouse-x != root.last-coords-x || root.mouse-y != root.last-coords-y) {
                root.last-coords-x = root.mouse-x;
                root.last-coords-y = root.mouse-y;
                let img-w = root.current-image.width;
                let img-h = root.current-image.height;
                if (img-w > 0 && img-h > 0) {
                    let rel-x = root.mouse-x - img-rect.x;
                    let rel-y = root.mouse-y - img-rect.y;
                    let scale = Math.min(img-rect.width / img-w, img-rect.height / img-h) * zoom-scale;
                    let vis-x = img-el.x + (img-el.width - img-w * scale) / 2;
                    let vis-y = img-el.y + (img-el.height - img-h * scale) / 2;
                    let x = clamp(Math.round((rel-x - vis-x) / scale), 0, img-w);
                    let y = clamp(Math.round((rel-y - vis-y) / scale), 0, img-h);
                    root.display-coords = x + "," + y;
                }
            }
        }
    }

    public function toggle-mouse-mode() {
        if (mouse-mode == MouseModeFull.default) {
            mouse-mode = MouseModeFull.segment;
        } else {
            mouse-mode = MouseModeFull.default;
        }
    }

    public function reset-zoom() {
        zoom-scale = 1;
        img-el.width = img-rect.width;
        img-el.height = img-rect.height;
        img-el.x = 0;
        img-el.y = 0;
    }

    function zoom(scale-delta: float, center-x: length, center-y: length) {
        let old-scale = zoom-scale;
        let new-scale = clamp(zoom-scale * scale-delta, 1, 10.0);
        if (old-scale == new-scale) {
            return;
        }
        let rel-x = center-x - img-rect.x;
        let rel-y = center-y - img-rect.y;
        let ratio = new-scale / old-scale;
        zoom-scale = new-scale;
        img-el.width = img-el.width * ratio;
        img-el.height = img-el.height * ratio;
        img-el.x = rel-x - (rel-x - img-el.x) * ratio;
        img-el.y = rel-y - (rel-y - img-el.y) * ratio;
    }

    function zoom-to-selection() {
        let zoom-factor = Math.min(img-rect.width / selection-width, img-rect.height / selection-height);
        let center-x = selection-x + selection-width / 2 + img-rect.x;
        let center-y = selection-y + selection-height / 2 + img-rect.y;
        zoom(zoom-factor, center-x, center-y);
        selection-width = 0px;
        selection-height = 0px;
    }

    pointer-event(event) => {
        if (event.button == PointerEventButton.middle) {
            if (event.kind == PointerEventKind.down) {
                root.start-drag-x = root.mouse-x;
                root.start-drag-y = root.mouse-y;
                root.start-img-x = img-el.x;
                root.start-img-y = img-el.y;
                root.dragging = true;
            } else if (event.kind == PointerEventKind.up) {
                root.dragging = false;
            }
        }
        if (event.button == PointerEventButton.left) {
            if (event.kind == PointerEventKind.down) {
                root.start-drag-x = root.mouse-x;
                root.start-drag-y = root.mouse-y;
                selection-width = 0px;
                selection-height = 0px;
            } else if (event.kind == PointerEventKind.up) {
                if (selection-width > 5px && selection-height > 5px && mouse-mode == MouseModeFull.default) {
                    zoom-to-selection();
                } else if ((selection-width <= 5px || selection-height <= 5px) && mouse-mode == MouseModeFull.segment) {
                    let img-w = root.current-image.width;
                    let img-h = root.current-image.height;
                    if (img-w > 0 && img-h > 0) {
                        let rel-x = root.mouse-x - img-rect.x;
                        let rel-y = root.mouse-y - img-rect.y;
                        let scale = Math.min(img-rect.width / img-w, img-rect.height / img-h) * zoom-scale;
                        let vis-x = img-el.x + (img-el.width - img-w * scale) / 2;
                        let vis-y = img-el.y + (img-el.height - img-h * scale) / 2;
                        let orig-x = clamp(Math.round((rel-x - vis-x) / scale), 0, img-w);
                        let orig-y = clamp(Math.round((rel-y - vis-y) / scale), 0, img-h);
                        root.request-segmentation(orig-x, orig-y);
                    }
                }
            }
        }
    }

    moved => {
        if (dragging == true && zoom-scale > 1.0) {
            img-el.x = root.start-img-x + (root.mouse-x - root.start-drag-x);
            img-el.y = root.start-img-y + (root.mouse-y - root.start-drag-y);
        }
        if (selecting && mouse-mode == MouseModeFull.default) {
            selection-x = Math.min(root.mouse-x, root.start-drag-x) - img-rect.x;
            selection-y = Math.min(root.mouse-y, root.start-drag-y) - img-rect.y;
            selection-width = Math.abs(root.mouse-x - root.start-drag-x);
            selection-height = Math.abs(root.mouse-y - root.start-drag-y);
        }
    }

    scroll-event(event) => {
        let scroll-up = event.delta-y > 0;
        if (event.modifiers.control) {
            zoom(scroll-up ? 1.1 : 0.9, root.mouse-x, root.mouse-y);
        } else if (zoom-scale == 1) { // floating point exact comparison, really?
            reset-zoom(); // not needed?
            if (scroll-up) {
                root.request-prev-image();
            } else {
                root.request-next-image();
            }
        }
        accept
    }

    HorizontalLayout {
        img-rect := Rectangle {
            horizontal-stretch: 1;
            clip: true;

            img-el := Image {
                source: root.current-image;
                image-fit: contain;
                width: parent.width;
                height: parent.height;
                x: 0px;
                y: 0px;
            }

            Image {
                source: root.mask-overlay;
                image-fit: contain;
                width: img-el.width;
                height: img-el.height;
                x: img-el.x;
                y: img-el.y;
            }

            Rectangle {
                height: 16px;
                y: parent.height - self.height;
                width: parent.width;
                background: Palette.background.with-alpha(50%);

                Text {
                    x: 5px;
                    text: (curr-image-index + 1) + "/" + root.total-images;
                }

                Text {
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    text: curr-image-name;
                }

                Text {
                    x: parent.width - self.width - 5px;
                    text: "[x,y]=[" + display-coords + "]";
                }
            }

            Rectangle {
                x: root.selection-x;
                y: root.selection-y;
                width: root.selection-width;
                height: root.selection-height;
                visible: root.selecting && root.mouse-mode == MouseModeFull.default;
                background: Palette.accent-background.with-alpha(25%);
                border-color: Palette.accent-background.with-alpha(75%);
                border-width: 1px;
            }

            ContextMenuArea {
                Menu {
                    MenuItem {
                        title: @tr("Rotate +90");
                        activated => {
                            root.apply-edit({ kind: EditOpKind.RotateCW, int-val: 0, float-val: 0 });
                        }
                    }

                    MenuItem {
                        title: @tr("Rotate -90");
                        activated => {
                            root.apply-edit({ kind: EditOpKind.RotateCCW, int-val: 0, float-val: 0 });
                        }
                    }

                    MenuItem {
                        title: @tr("Reset zoom");
                        activated => {
                            root.reset-zoom();
                        }
                    }

                    Menu {
                        title: @tr("Save with format");
                        MenuItem {
                            title: @tr("png");
                            activated => {
                                root.save-with-format(ImgFmt.png);
                            }
                        }

                        MenuItem {
                            title: @tr("jpeg");
                            activated => {
                                root.save-with-format(ImgFmt.jpeg);
                            }
                        }

                        MenuItem {
                            title: @tr("webp");
                            activated => {
                                root.save-with-format(ImgFmt.webp);
                            }
                        }
                    }
                }
            }
        }

        SidePanel {
            is-visible: root.panel-visible;
            side-width <=> root.side-panel-width;

            EditsPanel {
                apply-edit(op) => {
                    root.apply-edit(op);
                }
            }
        }
    }
}
