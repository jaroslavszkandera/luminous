import { Palette } from "std-widgets.slint";
import { ImgFmt, EditOp, EditOpKind } from "common.slint";
import { SidePanel } from "side-panel.slint";
import { EditsPanel } from "edits-panel.slint";
import { SelectRect } from "select-rect.slint";

export enum MouseModeFull {
    default,
    segment,
}

export component FullView inherits TouchArea {
    in property <image> current-image;
    in property <int> curr-image-index;
    in property <string> curr-image-name;
    in property <int> total-images;
    in property <bool> timer-running: false;
    in property <image> mask-overlay;
    in property <string> plugin-status;
    in-out property <bool> panel-visible: false;

    callback request-next-image();
    callback request-prev-image();
    callback exit-full-view();
    callback request-segmentation(int, int);
    callback save-with-format(ImgFmt);
    callback apply-edit(EditOp);

    property <string> display-coords: "0,0";
    property <float> zoom-scale: 1.0;
    property <length> last-coords-x;
    property <length> last-coords-y;
    property <MouseModeFull> mouse-mode: MouseModeFull.default;
    property <length> start-drag-x;
    property <length> start-drag-y;
    property <length> start-img-x;
    property <length> start-img-y;
    property <length> side-panel-width: 240px;
    property <bool> dragging: false;
    property <float> pinch-initial-scale: 1.0;

    property <float> img-render-scale: (root.current-image.width > 0 && root.current-image.height > 0) ? Math.min(img-el.width / root.current-image.width, img-el.height / root.current-image.height) / 1px : 1.0;

    property <length> img-vis-x: img-el.x + (img-el.width - root.current-image.width * 1px * img-render-scale) / 2;
    property <length> img-vis-y: img-el.y + (img-el.height - root.current-image.height * 1px * img-render-scale) / 2;

    mouse-cursor: (mouse-mode == MouseModeFull.segment) ? default : (root.dragging && zoom-scale > 1.0) ? grabbing : crosshair;

    coords-timer := Timer {
        interval: 60ms;
        running: root.timer-running;
        triggered => {
            if (root.mouse-x != root.last-coords-x || root.mouse-y != root.last-coords-y) {
                root.last-coords-x = root.mouse-x;
                root.last-coords-y = root.mouse-y;
                if (root.current-image.width > 0 && root.current-image.height > 0) {
                    let rel-x = root.mouse-x - img-rect.x;
                    let rel-y = root.mouse-y - img-rect.y;
                    let x = clamp(Math.round((rel-x - root.img-vis-x) / (root.img-render-scale * 1px)), 0, root.current-image.width);
                    let y = clamp(Math.round((rel-y - root.img-vis-y) / (root.img-render-scale * 1px)), 0, root.current-image.height);
                    root.display-coords = x + "," + y;
                }
            }
        }
    }

    public function toggle-mouse-mode() {
        mouse-mode = (mouse-mode == MouseModeFull.default) ? MouseModeFull.segment : MouseModeFull.default;
    }

    public function reset-zoom() {
        zoom-scale = 1;
        img-el.width = img-rect.width;
        img-el.height = img-rect.height;
        img-el.x = 0;
        img-el.y = 0;
    }

    function zoom(scale-delta: float, center-x: length, center-y: length) {
        let old-scale = zoom-scale;
        let new-scale = clamp(zoom-scale * scale-delta, 1, 10.0);
        if (old-scale == new-scale) {
            return;
        }
        let rel-x = center-x - img-rect.x;
        let rel-y = center-y - img-rect.y;
        let ratio = new-scale / old-scale;
        zoom-scale = new-scale;
        img-el.width = img-el.width * ratio;
        img-el.height = img-el.height * ratio;
        img-el.x = rel-x - (rel-x - img-el.x) * ratio;
        img-el.y = rel-y - (rel-y - img-el.y) * ratio;
    }

    function zoom-to-selection() {
        if (select-rect.selection.w < 1px || select-rect.selection.h < 1px) {
            return;
        }
        let cx = root.img-vis-x + (select-rect.selection.x + select-rect.selection.w / 2) * root.img-render-scale + img-rect.x;
        let cy = root.img-vis-y + (select-rect.selection.y + select-rect.selection.h / 2) * root.img-render-scale + img-rect.y;
        let zoom-factor = Math.min(img-rect.width / (select-rect.selection.w * root.img-render-scale), img-rect.height / (select-rect.selection.h * root.img-render-scale));
        zoom(zoom-factor, cx, cy);
    }

    function to-image-coords(screen-x: length, screen-y: length) -> {x: int, y: int} {
        let rel-x = screen-x - img-rect.x;
        let rel-y = screen-y - img-rect.y;
        return {
            x: clamp(Math.round((rel-x - root.img-vis-x) / (root.img-render-scale * 1px)), 0, root.current-image.width),
            y: clamp(Math.round((rel-y - root.img-vis-y) / (root.img-render-scale * 1px)), 0, root.current-image.height),
        };
    }

    pointer-event(event) => {
        if (event.button == PointerEventButton.middle) {
            if (event.kind == PointerEventKind.down) {
                root.start-drag-x = root.mouse-x;
                root.start-drag-y = root.mouse-y;
                root.start-img-x = img-el.x;
                root.start-img-y = img-el.y;
                root.dragging = true;
            } else if (event.kind == PointerEventKind.up) {
                root.dragging = false;
            }
        }
        if (event.button == PointerEventButton.left) {
            if (event.kind == PointerEventKind.down) {
                root.start-drag-x = root.mouse-x;
                root.start-drag-y = root.mouse-y;
                select-rect.show(root.mouse-x - img-rect.x, root.mouse-y - img-rect.y);
            } else if (event.kind == PointerEventKind.up) {
                if (select-rect.selection.w < 2px || select-rect.selection.h < 2px) {
                    if (mouse-mode == MouseModeFull.segment && root.current-image.width > 0) {
                        let coords = root.to-image-coords(root.mouse-x, root.mouse-y);
                        root.request-segmentation(coords.x, coords.y);
                    }
                    select-rect.hide();
                }
            }
        }
    }

    moved => {
        if (dragging && zoom-scale > 1.0) {
            img-el.x = root.start-img-x + (root.mouse-x - root.start-drag-x);
            img-el.y = root.start-img-y + (root.mouse-y - root.start-drag-y);
        }
        if (root.pressed && !dragging && mouse-mode == MouseModeFull.default) {
            select-rect.update-selection(
                { x: root.start-drag-x - img-rect.x, y: root.start-drag-y - img-rect.y },
                { x: root.mouse-x - img-rect.x, y: root.mouse-y - img-rect.y },
            );
        }
    }

    scroll-event(event) => {
        let scroll-up = event.delta-y > 0;
        if (event.modifiers.control) {
            zoom(scroll-up ? 1.1 : 0.9, root.mouse-x, root.mouse-y);
        } else {
            if (zoom-scale > 1) {
                return reject;
            }
            select-rect.cancelled();
            if (scroll-up) {
                root.request-prev-image();
            } else {
                root.request-next-image();
            }
        }
        accept
    }

    HorizontalLayout {
        img-rect := Rectangle {
            horizontal-stretch: 1;
            clip: true;

            img-el := Image {
                source: root.current-image;
                image-fit: contain;
                width: parent.width;
                height: parent.height;
                x: 0px;
                y: 0px;
            }

            Image {
                source: root.mask-overlay;
                image-fit: contain;
                width: img-el.width;
                height: img-el.height;
                x: img-el.x;
                y: img-el.y;
            }

            Rectangle {
                height: 16px;
                y: parent.height - self.height;
                width: parent.width;
                background: Palette.background.with-alpha(50%);

                Text {
                    x: 5px;
                    text: (curr-image-index + 1) + "/" + root.total-images;
                }

                Text {
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    text: curr-image-name;
                }

                Text {
                    x: parent.width - self.width - 5px;
                    text: "[x,y]=[" + display-coords + "]";
                }
            }

            select-rect := SelectRect {
                img-offset-x: root.img-vis-x;
                img-offset-y: root.img-vis-y;
                img-scale: root.img-render-scale;

                confirmed => {
                    if (select-rect.selection.w > 2px && select-rect.selection.h > 2px) {
                        root.zoom-to-selection();
                    }
                    select-rect.hide();
                }
                cancelled => {
                    select-rect.hide();
                }
            }

            ContextMenuArea {
                Menu {
                    MenuItem {
                        title: @tr("Rotate +90");
                        activated => {
                            root.apply-edit({ kind: EditOpKind.RotateCW, int-val: 0, float-val: 0 });
                        }
                    }

                    MenuItem {
                        title: @tr("Rotate -90");
                        activated => {
                            root.apply-edit({ kind: EditOpKind.RotateCCW, int-val: 0, float-val: 0 });
                        }
                    }

                    MenuItem {
                        title: @tr("Reset zoom");
                        activated => {
                            root.reset-zoom();
                        }
                    }

                    Menu {
                        title: @tr("Save with format");
                        MenuItem {
                            title: @tr("png");
                            activated => {
                                root.save-with-format(ImgFmt.png);
                            }
                        }

                        MenuItem {
                            title: @tr("jpeg");
                            activated => {
                                root.save-with-format(ImgFmt.jpeg);
                            }
                        }

                        MenuItem {
                            title: @tr("webp");
                            activated => {
                                root.save-with-format(ImgFmt.webp);
                            }
                        }
                    }
                }
            }
        }

        SidePanel {
            is-visible: root.panel-visible;
            side-width <=> root.side-panel-width;
            EditsPanel {
                apply-edit(op) => {
                    root.apply-edit(op);
                }
            }
        }
    }
}
