import { Palette } from "std-widgets.slint";

enum CornerSide { min, max }
export struct ImgRect { x: length, y: length, w: length, h: length}

struct HandleDef {
    cursor: MouseCursor,
    side-x: CornerSide,
    side-y: CornerSide,
}

export component SelectRect inherits Rectangle {
    background: Palette.accent-background.with-alpha(25%);
    border-color: Palette.accent-background.with-alpha(75%);
    border-width: 1px;
    visible: false;

    in property <length> img-offset-x;
    in property <length> img-offset-y;
    in property <float> img-scale;

    in property <length> handle-size: 8px;
    in property <length> handle-touch-radius: 20px;

    out property <ImgRect> selection: {
        x: Math.min(anchor.x, opposite.x),
        y: Math.min(anchor.y, opposite.y),
        w: Math.abs(opposite.x - anchor.x),
        h: Math.abs(opposite.y - anchor.y),
    };

    callback confirmed();
    callback cancelled();

    property <Point> anchor;
    property <Point> opposite;

    property <int> active-handle: -1;
    property <bool> dragging-body: false;
    property <Point> drag-start-mouse;
    property <Point> drag-start-anchor;
    property <Point> drag-start-opposite;

    function screen-to-img(sx: length, sy: length) -> Point {
        return {
            x: (sx - img-offset-x) / (img-scale),
            y: (sy - img-offset-y) / (img-scale),
        };
    }
    function img-to-screen-x(ix: length) -> length {
        img-offset-x + ix * img-scale
    }
    function img-to-screen-y(iy: length) -> length {
        img-offset-y + iy * img-scale
    }

    x: img-to-screen-x(Math.min(anchor.x, opposite.x));
    y: img-to-screen-y(Math.min(anchor.y, opposite.y));
    width: Math.abs(opposite.x - anchor.x) * img-scale;
    height: Math.abs(opposite.y - anchor.y) * img-scale;

    public function show(screen-x: length, screen-y: length) {
        let p = screen-to-img(screen-x, screen-y);
        anchor = p;
        opposite = p;
        self.visible = true;
    }

    public function hide() {
        self.visible = false;
    }

    public function update-selection(screen-anchor: {x: length, y: length}, screen-opposite: {x: length, y: length}) {
        anchor = screen-to-img(screen-anchor.x,   screen-anchor.y);
        opposite = screen-to-img(screen-opposite.x, screen-opposite.y);
    }

    body-ta := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: dragging-body ? MouseCursor.grabbing : MouseCursor.move;

        pointer-event(e) => {
            if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                root.confirmed();
            }
            if (e.button == PointerEventButton.middle) {
                if (e.kind == PointerEventKind.down) {
                    root.drag-start-mouse = root.screen-to-img(self.mouse-x + root.x, self.mouse-y + root.y);
                    root.drag-start-anchor = root.anchor;
                    root.drag-start-opposite = root.opposite;
                    root.dragging-body = true;
                } else if (e.kind == PointerEventKind.up) {
                    root.dragging-body = false;
                }
            }
        }

        moved => {
            if (!root.dragging-body) {
                return;
            }
            let mouse = root.screen-to-img(self.mouse-x + root.x, self.mouse-y + root.y);
            let dx = mouse.x - root.drag-start-mouse.x;
            let dy = mouse.y - root.drag-start-mouse.y;
            root.anchor = { x: root.drag-start-anchor.x + dx, y: root.drag-start-anchor.y + dy };
            root.opposite = { x: root.drag-start-opposite.x + dx, y: root.drag-start-opposite.y + dy };
        }
    }

    for handle-def[i] in [
        { cursor: MouseCursor.nwse-resize, side-x: CornerSide.min, side-y: CornerSide.min },
        { cursor: MouseCursor.nesw-resize, side-x: CornerSide.max, side-y: CornerSide.min },
        { cursor: MouseCursor.nesw-resize, side-x: CornerSide.min, side-y: CornerSide.max },
        { cursor: MouseCursor.nwse-resize, side-x: CornerSide.max, side-y: CornerSide.max },
    ]: Rectangle {
        property <length> corner-screen-x: handle-def.side-x == CornerSide.min ? root.img-to-screen-x(Math.min(root.anchor.x, root.opposite.x)) : root.img-to-screen-x(Math.max(root.anchor.x, root.opposite.x));
        property <length> corner-screen-y: handle-def.side-y == CornerSide.min ? root.img-to-screen-y(Math.min(root.anchor.y, root.opposite.y)) : root.img-to-screen-y(Math.max(root.anchor.y, root.opposite.y));

        x: corner-screen-x - root.x - root.handle-size / 2;
        y: corner-screen-y - root.y - root.handle-size / 2;
        width: root.handle-size;
        height: root.handle-size;
        background: Palette.accent-background;

        TouchArea {
            property <length> r: root.handle-touch-radius;
            x: (root.handle-size - 2 * r) / 2;
            y: (root.handle-size - 2 * r) / 2;
            width: 2 * r;
            height: 2 * r;
            mouse-cursor: handle-def.cursor;

            pointer-event(e) => {
                if (e.button == PointerEventButton.left) {
                    if (e.kind == PointerEventKind.down) {
                        root.active-handle = i;
                        root.drag-start-mouse = root.screen-to-img(self.mouse-x + parent.x + root.x, self.mouse-y + parent.y + root.y);
                        root.drag-start-anchor = root.anchor;
                        root.drag-start-opposite = root.opposite;
                    } else if (e.kind == PointerEventKind.up) {
                        root.active-handle = -1;
                    }
                }
            }

            moved => {
                if (root.active-handle != i) {
                    return;
                }
                let mouse = root.screen-to-img(self.mouse-x + parent.x + root.x, self.mouse-y + parent.y + root.y);
                let dx = mouse.x - root.drag-start-mouse.x;
                let dy = mouse.y - root.drag-start-mouse.y;
                if (handle-def.side-x == CornerSide.max) {
                    root.opposite = { x: root.drag-start-opposite.x + dx, y: root.opposite.y };
                } else {
                    root.anchor = { x: root.drag-start-anchor.x + dx, y: root.anchor.y };
                }
                if (handle-def.side-y == CornerSide.max) {
                    root.opposite = { x: root.opposite.x, y: root.drag-start-opposite.y + dy };
                } else {
                    root.anchor = { x: root.anchor.x, y: root.drag-start-anchor.y + dy };
                }
            }
        }
    }
}
