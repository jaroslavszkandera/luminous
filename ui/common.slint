export enum ViewMode {
    full,
    grid,
}

export enum ImgFmt {
    png,
    jpeg,
    webp,
}

export enum EditOpKind {
    RotateCW,
    RotateCCW,
    FlipH,
    FlipV,
    Brighten,
    Contrast,
    Crop,
    ColorSpace,
    Reset,
}

export enum Channel {
    Gray,
    Red,
    Green,
    Blue,
    Hue,
    Saturation,
    Value,
}

export struct EditOp {
    kind: EditOpKind,
    int-val: int,
    float-val: float,
    string-val: string,
}

export struct GridItem {
    image: image,
    index: int,
    abs_index: int,
    selected: bool,
}
