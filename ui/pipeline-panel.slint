import {
    Button,
    ScrollView,
    LineEdit,
    ComboBox,
    Palette,
    ProgressIndicator,
} from "std-widgets.slint";
import { Channel } from "common.slint";

export enum RotateAngle {
    R90,
    R180,
    R270,
    Random,
}

export enum FlipDirection {
    Horizontal,
    Vertical,
}

export enum PipelineStepKind {
    Rotate,
    GaussianBlur,
    Brighten,
    Resize,
    ExtractChannel,
    Flip,
}

export struct PipelineStep {
    kind: PipelineStepKind,
    rotate-angle: RotateAngle,
    blur-sigma: float,
    brighten-value: int,
    resize-width: int,
    resize-height: int,
    flip-direction: FlipDirection,
    extract-channel: Channel,
}

component CloseButton inherits Button {
    height: 20px;
    text: "\u{1F5D9}";
}

component StepCard inherits Rectangle {
    in property <string> title;
    callback remove();

    height: 76px;
    border-color: Palette.border;
    border-radius: 6px;
    border-width: 1px;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 6px;
            Text {
                text: root.title;
                font-size: 12px;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            CloseButton {
                clicked => {
                    root.remove();
                }
            }
        }

        @children
    }
}

export component RotateStepCard inherits StepCard {
    title: "Rotate";
    in-out property <RotateAngle> angle: RotateAngle.R90;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "Angle";
            font-size: 12px;
            vertical-alignment: center;
            width: 44px;
        }

        ComboBox {
            model: ["90°", "180°", "270°", "Random"];
            current-index: root.angle == RotateAngle.R90 ? 0 : root.angle == RotateAngle.R180 ? 1 : root.angle == RotateAngle.R270 ? 2 : 3;
            selected(val) => {
                root.angle = val == "90°" ? RotateAngle.R90 : val == "180°" ? RotateAngle.R180 : val == "270°" ? RotateAngle.R270 : RotateAngle.Random;
                root.changed();
            }
        }
    }
}

export component GaussianBlurStepCard inherits StepCard {
    title: "Gaussian Blur";
    in-out property <float> sigma: 1.0;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "Sigma:";
            font-size: 12px;
            vertical-alignment: center;
            width: 44px;
        }

        LineEdit {
            text: root.sigma;
            input-type: number;
            placeholder-text: "1.0";
            edited(val) => {
                let f = val.to-float();
                if (f > 0.0) {
                    root.sigma = f;
                    root.changed();
                }
            }
        }

        Text {
            text: "px";
            font-size: 10px;
            vertical-alignment: center;
        }
    }
}

export component BrightenStepCard inherits StepCard {
    title: "Brighten";
    in-out property <int> value: 10;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "Value:";
            font-size: 12px;
            vertical-alignment: center;
            width: 44px;
        }

        LineEdit {
            text: root.value;
            input-type: number;
            placeholder-text: "10";
            edited(val) => {
                root.value = val.to-float();
                root.changed();
            }
        }

        Text {
            text: "(-255 - 255)";
            font-size: 9px;
            vertical-alignment: center;
        }
    }
}

export component ResizeStepCard inherits StepCard {
    title: "Resize";
    in-out property <int> w: 224;
    in-out property <int> h: 224;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "W:";
            font-size: 12px;
            vertical-alignment: center;
            width: 16px;
        }

        LineEdit {
            text: root.w;
            input-type: number;
            edited(val) => {
                root.w = Math.max(1, val.to-float());
                root.changed();
            }
        }

        Text {
            text: "H:";
            font-size: 12px;
            vertical-alignment: center;
            width: 16px;
        }

        LineEdit {
            text: root.h;
            input-type: number;
            edited(val) => {
                root.h = Math.max(1, val.to-float());
                root.changed();
            }
        }
    }
}

export component FlipStepCard inherits StepCard {
    title: "Flip";
    in-out property <FlipDirection> direction: FlipDirection.Horizontal;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "Dir:";
            font-size: 12px;
            vertical-alignment: center;
            width: 30px;
        }

        ComboBox {
            model: ["Horizontal", "Vertical"];
            current-index: root.direction == FlipDirection.Horizontal ? 0 : 1;
            selected(val) => {
                root.direction = val == "Horizontal" ? FlipDirection.Horizontal : FlipDirection.Vertical;
                root.changed();
            }
        }
    }
}

export component ExtractChannelStepCard inherits StepCard {
    title: "Extract Channel";
    in-out property <Channel> channel: Channel.Gray;
    callback changed();

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: "Channel:";
            font-size: 12px;
            vertical-alignment: center;
            width: 50px;
        }

        ComboBox {
            model: ["Gray", "Red", "Green", "Blue", "Hue", "Saturation", "Value"];
            current-index: root.channel == Channel.Gray ? 0 : root.channel == Channel.Red ? 1 : root.channel == Channel.Green ? 2 : root.channel == Channel.Blue ? 3 : root.channel == Channel.Hue ? 4 : root.channel == Channel.Saturation ? 5 : 6;
            selected(val) => {
                root.channel = val == "Gray" ? Channel.Gray : val == "Red" ? Channel.Red : val == "Green" ? Channel.Green : val == "Blue" ? Channel.Blue : val == "Hue" ? Channel.Hue : val == "Saturation" ? Channel.Saturation : Channel.Value;
                root.changed();
            }
        }
    }
}

component AddStepMenu inherits Rectangle {
    callback add-step(PipelineStepKind);
    height: 28px;

    ComboBox {
        model: [
            "Add step",
            "Rotate",
            "Brighten",
            "Gaussian Blur",
            "Resize",
            "Extract Channel",
            "Flip"
        ];
        selected(val) => {
            if (val == "Rotate") {
                root.add-step(PipelineStepKind.Rotate);
            } else if (val == "Brighten") {
                root.add-step(PipelineStepKind.Brighten);
            } else if (val == "Gaussian Blur") {
                root.add-step(PipelineStepKind.GaussianBlur);
            } else if (val == "Resize") {
                root.add-step(PipelineStepKind.Resize);
            } else if (val == "Extract Channel") {
                root.add-step(PipelineStepKind.ExtractChannel);
            } else if (val == "Flip") {
                root.add-step(PipelineStepKind.Flip);
            }
            self.current-index = 0;
        }
    }
}

export component PipelinePanel inherits Rectangle {
    in-out property <[PipelineStep]> steps;
    in property <float> progress;
    in property <[string]> encoder_extensions;
    callback request-add-step(PipelineStepKind);
    callback request-remove-step(int);
    callback request-update-step(int, PipelineStep);
    callback run-pipeline(string);

    changed progress => {
        debug(progress);
        if abs(progress - 1.0) < 0.01 {
            debug("pipeline-finished");
            save-btn.enabled = true;
        } else if (progress > 0) {
            save-btn.enabled = false;
        }
    }

    HorizontalLayout {
        padding: 6px;
        VerticalLayout {
            spacing: 6px;
            Rectangle {
                VerticalLayout {
                    Text {
                        text: "Pipeline";
                        font-size: 14px;
                        font-weight: 700;
                    }

                    AddStepMenu {
                        add-step(k) => {
                            root.request-add-step(k);
                        }
                    }
                }
            }

            ScrollView {
                viewport-height: steps.length * 76px;
                VerticalLayout {
                    for step[i] in root.steps: Rectangle {
                        if step.kind == PipelineStepKind.Rotate: RotateStepCard {
                            angle: step.rotate-angle;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.rotate-angle = self.angle;
                                root.request-update-step(i, step);
                            }
                        }
                        if step.kind == PipelineStepKind.GaussianBlur: GaussianBlurStepCard {
                            sigma: step.blur-sigma;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.blur-sigma = self.sigma;
                                root.request-update-step(i, step);
                            }
                        }
                        if step.kind == PipelineStepKind.Brighten: BrightenStepCard {
                            value: step.brighten-value;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.brighten-value = self.value;
                                root.request-update-step(i, step);
                            }
                        }
                        if step.kind == PipelineStepKind.Resize: ResizeStepCard {
                            w: step.resize-width;
                            h: step.resize-height;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.resize-width = self.w;
                                step.resize-height = self.h;
                                root.request-update-step(i, step);
                            }
                        }
                        if step.kind == PipelineStepKind.Flip: FlipStepCard {
                            direction: step.flip-direction;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.flip-direction = self.direction;
                                root.request-update-step(i, step);
                            }
                        }
                        if step.kind == PipelineStepKind.ExtractChannel: ExtractChannelStepCard {
                            channel: step.extract-channel;
                            remove => {
                                root.request-remove-step(i);
                            }
                            changed => {
                                step.extract-channel = self.channel;
                                root.request-update-step(i, step);
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                save-btn := Button {
                    text: "Save";
                    height: 34px;
                    primary: true;
                    clicked => {
                        root.run-pipeline(extensions-combo-box.current-value);
                    }
                }

                extensions-combo-box := ComboBox {
                    model: encoder_extensions;
                }
            }

            HorizontalLayout {
                height: 30px;
                spacing: 3px;
                Text {
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    text: "Progress:";
                }

                progress-indicator := ProgressIndicator {
                    indeterminate: false;
                    progress <=> root.progress;
                }
            }
        }
    }
}
