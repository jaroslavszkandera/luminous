import { ScrollView, LineEdit, Button, Palette } from "std-widgets.slint";
import { ImgFmt, GridItem } from "common.slint";
import {
    SidePanel,
    PipelinePanel,
    PipelineStep,
    PipelineStepKind,
    RotateAngle,
} from "side-panel.slint";

export component GridView inherits Rectangle {
    in property <[GridItem]> model;
    in property <[GridItem]> visible-model;
    in-out property <int> grid-cols: 5;
    in-out property <int> selected-count: 0;
    in-out property <bool> panel-visible: false;
    in-out property <length> side-panel-width: 240px;
    in-out property <[PipelineStep]> pipeline-steps;

    property <int> last-clicked-index: -1;

    callback request-grid-data(int, int);
    callback image-selected(int);
    callback bucket-resolution-changed(int);
    callback search-submitted(string);
    callback toggle-select-all(bool);
    callback request-range-select(int, int);
    callback print-selected-paths();
    callback toggle-selection(int);
    callback batch-save-with-format(ImgFmt);
    callback pipeline-add-step(PipelineStepKind);
    callback pipeline-remove-step(int);
    callback pipeline-update-rotate(int, RotateAngle);
    callback pipeline-update-sigma(int, float);
    callback pipeline-update-brighten(int, int);
    callback pipeline-run();

    public function focus-search() {
        search-input.focus();
    }

    public function page-down() {
        scroll-area.viewport-y = Math.max(
            scroll-area.viewport-y - scroll-area.height,
            scroll-area.height - scroll-area.viewport-height);
        update-visible-rows();
    }

    public function page-up() {
        scroll-area.viewport-y = Math.min(
            scroll-area.viewport-y + scroll-area.height,
            0px);
        update-visible-rows();
    }

    public function update-visible-rows() {
        let item-h = grid-container.item-size + grid-container.gap;
        let cols = grid-container.cols;
        if (item-h > 1px && root.height > 1px) {
            let start-row = floor(-scroll-area.viewport-y / item-h);
            let screen-rows = ceil(scroll-area.height / item-h);
            let buffer-rows = 5;
            let start-index = Math.max(0, (start-row - buffer-rows) * cols);
            let total-count = (screen-rows + (buffer-rows * 2)) * cols;
            root.request-grid-data(start-index, total-count);
        }
    }

    public function update-grid-cols(cols: int) {
        root.grid-cols = clamp(cols, 2, 20);
        scroll-area.sync-bucket-resolution();
        update-visible-rows();
    }

    VerticalLayout {
        Rectangle {
            background: Palette.background;
            width: 100%;
            height: 35px;

            HorizontalLayout {
                padding: 5px;
                spacing: 30px;

                Button {
                    text: selected-count > 0 ? selected-count + "/" + model.length : model.length;
                    clicked => {
                        root.toggle-select-all(selected-count > 0);
                        root.selected-count = selected-count > 0 ? 0 : model.length;
                    }
                }

                search-input := LineEdit {
                    placeholder-text: "Search";
                    font-size: 16px;
                    accepted(text) => {
                        root.search-submitted(self.text);
                        self.clear-focus();
                    }
                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            self.text = "";
                            root.search-submitted("");
                            self.clear-focus();
                            return accept;
                        }
                        reject
                    }
                }

                Button {
                    icon: @image-url("icons/menu_icon_251951.svg");
                    colorize-icon: true;
                    checked: panel-visible;
                    clicked => {
                        panel-visible = !panel-visible;
                    }
                }
            }
        }

        Rectangle {
            scroll-area := ScrollView {
                x: 0;
                width: parent.width - side-panel.width;
                viewport-height: grid-touch.height;
                property <[length]> resolutions: [256 * 1px, 512 * 1px, 1024 * 1px];

                function bucket-resolution(size: length) -> int {
                    if size < resolutions[0] {
                        return resolutions[0] / 1px;
                    }
                    if size < resolutions[1] {
                        return resolutions[1] / 1px;
                    }
                    return resolutions[2] / 1px;
                }

                function sync-bucket-resolution() {
                    let new-res = bucket-resolution(grid-container.item-size);
                    if (new-res != grid-container.curr-bucket-res) {
                        grid-container.curr-bucket-res = new-res;
                        root.bucket-resolution-changed(new-res);
                    }
                }

                scrolled => {
                    root.update-visible-rows();
                }
                init => {
                    root.update-visible-rows();
                }
                changed height => {
                    root.update-visible-rows();
                }
                changed width => {
                    sync-bucket-resolution();
                    root.update-visible-rows();
                }

                grid-touch := TouchArea {
                    property <int> cols: root.grid-cols;
                    property <length> gap: 0px;
                    property <length> item-size: (parent.width - (cols + 1) * gap) / cols;
                    property <int> rows: (root.model.length + cols - 1) / cols;
                    height: (rows * item-size) + ((rows + 1) * gap);

                    scroll-event(event) => {
                        if (event.modifiers.control) {
                            let delta = event.delta-y > 0 ? -1 : 1;
                            root.update-grid-cols(root.grid-cols + delta);
                            accept
                        } else {
                            reject
                        }
                    }

                    grid-container := Rectangle {
                        height: parent.height;
                        property <length> item-size: grid-touch.item-size;
                        property <length> gap: grid-touch.gap;
                        property <int> cols: grid-touch.cols;
                        property <int> curr-bucket-res: 0;

                        for item in root.visible-model: Rectangle {
                            width: parent.item-size;
                            height: parent.item-size;
                            x: (Math.mod(item.index, parent.cols) * (parent.item-size + parent.gap)) + parent.gap;
                            y: (floor(item.index / parent.cols) * (parent.item-size + parent.gap)) + parent.gap;
                            clip: true;
                            border-width: item.selected ? 3px : 0px;
                            border-color: item.selected ? Palette.accent-background : transparent;
                            background: item.selected ? Palette.accent-background.with-alpha(30%) : transparent;
                            animate border-width {
                                duration: 150ms;
                                easing: ease-in-out;
                            }

                            Image {
                                source: item.image;
                                image-fit: cover;
                                width: 100%;
                                height: 100%;
                                opacity: item.selected ? 0.7 : 1.0;
                            }

                            TouchArea {
                                pointer-event(event) => {
                                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                        if (event.modifiers.control) {
                                            root.toggle-selection(item.index);
                                            root.last-clicked-index = item.index;
                                        } else if (event.modifiers.shift && root.last-clicked-index != -1) {
                                            root.request-range-select(root.last-clicked-index, item.index);
                                        }
                                    }
                                }
                                double-clicked => {
                                    root.image-selected(item.index);
                                }
                            }
                        }
                    }

                    ContextMenuArea {
                        Menu {
                            MenuItem {
                                title: @tr("Print selected paths to stdout");
                                activated => {
                                    root.print-selected-paths();
                                }
                            }

                            MenuItem {
                                title: @tr("Toggle Filter Panel");
                                activated => {
                                    panel-visible = !panel-visible;
                                }
                            }

                            Menu {
                                title: @tr("Convert to...");
                                MenuItem {
                                    title: @tr("png");
                                    activated => {
                                        root.batch-save-with-format(ImgFmt.png);
                                        root.toggle-select-all(false);
                                    }
                                }

                                MenuItem {
                                    title: @tr("jpeg");
                                    activated => {
                                        root.batch-save-with-format(ImgFmt.jpeg);
                                        root.toggle-select-all(false);
                                    }
                                }

                                MenuItem {
                                    title: @tr("webp");
                                    activated => {
                                        root.batch-save-with-format(ImgFmt.webp);
                                        root.toggle-select-all(false);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            side-panel := SidePanel {
                x: parent.width - self.width;
                is-visible: root.panel-visible;
                side-width <=> root.side-panel-width;

                PipelinePanel {
                    width: parent.width;
                    height: parent.height;
                    steps <=> root.pipeline-steps;
                    request-add-step(kind) => {
                        root.pipeline-add-step(kind);
                    }
                    request-remove-step(i) => {
                        root.pipeline-remove-step(i);
                    }
                    request-update-rotate(i, a) => {
                        root.pipeline-update-rotate(i, a);
                    }
                    request-update-sigma(i, s) => {
                        root.pipeline-update-sigma(i, s);
                    }
                    request-update-brighten(i, b) => {
                        root.pipeline-update-brighten(i, b);
                    }
                    run-pipeline() => {
                        root.pipeline-run();
                    }
                }
            }
        }
    }
}
